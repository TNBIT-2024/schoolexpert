# Copy this file to .env and fill in your Firebase project configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Auth Hashing Configuration (for password migration / import)
VITE_FIREBASE_HASH_ALGORITHM=SCRYPT
VITE_FIREBASE_HASH_SIGNER_KEY=your_base64_signer_key
VITE_FIREBASE_HASH_SALT_SEPARATOR=your_base64_salt_separator
VITE_FIREBASE_HASH_ROUNDS=8
VITE_FIREBASE_HASH_MEM_COST=14

